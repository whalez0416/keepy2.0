# App Settings
APP_NAME=Keepy MVP
DEBUG=True

# Database
DATABASE_URL=sqlite:///./keepy.db

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=no-reply@keepy.com

# Alert Settings
ALERT_COOLDOWN_HOURS=1
HOMEPAGE_FAIL_THRESHOLD=2
FORM_FAIL_THRESHOLD=1
